---
import Layout from "../layouts/Layout.astro";
import RunningHead from "../components/RunningHead.astro";
import SectionHeader from "../components/SectionHeader.astro";
import Plate from "../components/Plate.astro";
import PhoneFrame from "../components/PhoneFrame.astro";
import DeliveredToken from "../components/DeliveredToken.astro";
import ArchitectureCallout from "../components/ArchitectureCallout.astro";
import { Image } from "astro:assets";

// writequit (dark / terminal)
import wqBoard from "../../content/images/pitch/writequit-board.webp";
import wqTime from "../../content/images/pitch/writequit-time.webp";
import wqInvoice from "../../content/images/pitch/writequit-invoice.webp";
import wqBoardAdmin from "../../content/images/pitch/writequit-board-admin.webp";
import wqClient from "../../content/images/pitch/writequit-client-board.webp";

// pondera (light / friendly)
import poCole from "../../content/images/pitch/pondera-cole.png";
import poPontue from "../../content/images/pitch/pondera-pontue.png";
import poCompare from "../../content/images/pitch/pondera-compare.png";
import poDecida from "../../content/images/pitch/pondera-decida.png";

// Flora (Santos Lab)
import flMapa from "../../content/images/Flora-Mapa.png";
import flDash from "../../content/images/Flora-Dashboard.png";
import flMapaF from "../../content/images/Flora-MapaF.png";
import flApp from "../../content/images/FloraApp-SelectedFarm.png";

// public-facing work
import hoPortal from "../../content/images/HomeOptions.png";
import hoBlog from "../../content/images/HomeOptionsBlog.png";
import liftPortal from "../../content/images/LiftUpPortal.png";

// range / build-for-fun
import gameTitle from "../../content/images/StupidSpiderGameTitle.png";
import gameIG from "../../content/images/StupidSpiderGameIG.png";
import sudoTitle from "../../content/images/SudokouijaTitle.png";
import sudoBoard from "../../content/images/SudokouijaBoard.png";
import goHtmx from "../../content/images/go-htmx.webp";
import gleamHtmx from "../../content/images/HTMX_Gleam.png";

// logo
import niterraLogo from "../../content/images/venturelabngk_logo.jpg";

// Niterra Ventures — demo app screens (clean-slate instance, fictional data)
import niDash from "../../content/images/niterra/niterra-dashboard.png";
import niCompanies from "../../content/images/niterra/niterra-companies.png";
import niCompany from "../../content/images/niterra/niterra-company.png";
import niValuation from "../../content/images/niterra/niterra-valuation.png";
import niCaptable from "../../content/images/niterra/niterra-captable.png";
import niFunnel from "../../content/images/niterra/niterra-funnel.png";
import niExpend from "../../content/images/niterra/niterra-expenditures.png";
import niAccuracy from "../../content/images/niterra/niterra-accuracy.png";
import niPresentation from "../../content/images/niterra/niterra-presentation.png";
import niReports from "../../content/images/niterra/niterra-reports.png";

const niStats = [
  {
    big: "120h → 1 day",
    label: "Quarterly portfolio deck",
    note: "Took the senior principal ~120 hrs by hand each quarter. The tool exports it in seconds; he finishes it by hand in about a day.",
  },
  {
    big: "40+ users",
    label: "Across the firm",
    note: "The investment team's daily system of record — 10+ of them in it 2+ hrs a day.",
  },
  {
    big: "8 → 1",
    label: "One source of truth",
    note: "Eight sprawling Excel sheets — some enormous — consolidated into one platform.",
  },
  {
    big: "~1 hr / co / qtr",
    label: "Saved on report intake",
    note: "Quarterly company reports map straight in from Excel — no re-keying, every quarter, every company.",
  },
];

const homeOptionsMap = [
  "SvelteKit CRM  ◀──▶  Twilio call center",
  "      │",
  "      ├──▶  AI-assisted call-handoff",
  "      └──▶  Go / HTMX compliance & debt-settlement",
];
---

<Layout title="Felipe Afonso — A product team of one">
  <RunningHead />

  <main id="top">
    <!-- ============ 01 · HERO ============ -->
    <section
      data-folio="01"
      data-title="Cover"
      class="wrap flex min-h-[82svh] flex-col justify-center pb-[var(--space-section)]"
      style="padding-top: calc(var(--running-head-h) + 5vh);"
    >
      <p class="kicker reveal text-accent">
        <span aria-hidden="true">01</span>
        <span class="ml-4 sm:ml-6">
          Software Engineer · Full-Stack · End-to-End Ownership
        </span>
      </p>
      <h1
        class="t-display reveal reveal-1 text-ink mt-6 max-w-[16ch] text-[clamp(2.75rem,6vw+1rem,6.5rem)]"
      >
        Hand me a problem. I'll hand back a <span class="draw-underline">
          working product
        </span><span class="text-accent">.</span>
      </h1>
      <p
        class="reveal reveal-2 col-measure text-ink mt-8 text-[clamp(1.0625rem,0.5vw+1rem,1.25rem)] leading-relaxed"
      >
        I work like an embedded product team of one: I take a problem from rough
        idea to a running product — design, build, deploy — with minimal
        hand-offs in between.
      </p>
      <div
        class="reveal reveal-3 mt-10 flex flex-col gap-3 text-sm sm:flex-row sm:gap-10"
      >
        <a class="ed-link" href="mailto:fmunhozafonso@gmail.com">
          Start a conversation → fmunhozafonso@gmail.com
        </a>
        <a class="ed-link" target="_blank" href="/resume.pdf">
          /resume.pdf — the full record
        </a>
      </div>
    </section>

    <!-- ============ 02 · HOW I WORK ============ -->
    <section data-folio="02" data-title="Operating Model">
      <SectionHeader folio="02" kicker="Operating Model" id="how" />
      <div class="wrap mt-6">
        <p
          class="reveal text-ink max-w-[64ch] text-[clamp(1.25rem,1vw+1rem,1.6rem)] leading-snug"
        >
          I tend to take a problem end-to-end — design, build, deploy, and the
          parts no one volunteers for: auth, billing, the deploy pipeline — so
          it lands as one decision instead of a chain of hand-offs.
        </p>
        <p class="reveal reveal-1 col-measure text-ink mt-5 leading-relaxed">
          I'm comfortable across the stack and across languages, so I can
          usually reach for the tool a problem wants rather than the one I
          happen to know. I lean on AI as a multiplier on delivery speed — it's
          a big part of why the work below — a complete internal platform for a
          venture firm, plus two commercial products of my own — each shipped
          from one pair of hands. I've also led a small team, so I'm comfortable
          coordinating when a problem is bigger than one person.
        </p>
      </div>
    </section>

    <!-- ============ 03 · NITERRA — FLAGSHIP ============ -->
    <section
      data-folio="03"
      data-title="Flagship — Niterra Ventures"
      class="relative mt-[var(--space-section)]"
    >
      <div class="mx-auto w-full max-w-[var(--content-max)] px-[var(--gutter)]">
        <div
          class="border-rule relative overflow-hidden rounded-[var(--panel-radius)] border"
          style="box-shadow: var(--shadow-paper);"
        >
          <!-- ===== BAND 1 · dark masthead ===== -->
          <div
            class="bg-ni-deep relative overflow-hidden pt-14 pb-28 lg:pt-20 lg:pb-40"
          >
            <!-- contained teal glow (clipped by overflow-hidden — can't bleed into §02) -->
            <div
              aria-hidden="true"
              class="pointer-events-none absolute inset-x-0 top-0 z-0 h-[60vh]"
              style="background: radial-gradient(48% 50% at 50% 0%, color-mix(in oklch, var(--color-ni-teal) 18%, transparent), transparent 70%);"
            >
            </div>
            <!-- faint secondary glow, lower-right -->
            <div
              aria-hidden="true"
              class="pointer-events-none absolute right-0 -bottom-[10vh] z-0 h-[40vh] w-[55vw]"
              style="background: radial-gradient(50% 50% at 80% 60%, color-mix(in oklch, var(--color-ni-teal) 9%, transparent), transparent 72%);"
            >
            </div>

            <div class="relative z-10 px-[var(--gutter)]">
              <header id="niterra">
                <div class="grid grid-cols-12 items-baseline gap-x-4">
                  <div
                    class="kicker reveal text-ni-teal col-span-12 lg:col-span-1"
                    aria-hidden="true"
                  >
                    03
                  </div>
                  <div class="col-span-12 lg:col-span-11">
                    <div class="reveal flex items-center gap-3">
                      <Image
                        src={niterraLogo}
                        alt=""
                        width={36}
                        height={36}
                        class="border-ni-teal/25 rounded-[3px] border"
                      />
                      <p class="kicker text-ni-teal">
                        Flagship · Internal platform, shipped solo
                      </p>
                    </div>
                    <h2
                      class="t-headline reveal reveal-1 text-ni-paper mt-4 text-[clamp(2rem,3.5vw+1rem,4.25rem)]"
                    >
                      Niterra Ventures
                    </h2>
                    <p
                      class="t-emph reveal reveal-1 col-measure text-ni-paper mt-5 text-[clamp(1.4rem,1.4vw+1rem,2rem)] leading-snug"
                    >
                      The investment team's work lived across a CRM and a stack
                      of spreadsheets. I built one internal platform to bring it
                      together — and it became how the team works.
                    </p>
                  </div>
                </div>
              </header>

              <div class="mt-8 grid gap-x-12 gap-y-6 lg:grid-cols-12">
                <p
                  class="reveal text-ni-paper/85 text-[1.0625rem] leading-relaxed lg:col-span-7"
                >
                  Built for the venture arm of Niterra Group, it's the system of
                  record for the whole investment lifecycle: portfolio companies
                  and their quarterly financials, editable cap tables,
                  scenario-based exit models, a deal funnel, expense & contract
                  tracking, board-deck generation, and P&amp;L / balance-sheet
                  reporting — fed by live integrations and mapped Excel imports.
                </p>
                <p
                  class="reveal reveal-1 text-ni-paper/55 font-mono text-[0.8rem] leading-relaxed lg:col-span-5"
                >
                  <span class="text-ni-teal">stack</span> · SvelteKit · Svelte 5 ·
                  Bun · TypeScript · Tailwind 4 · shadcn-svelte · Drizzle / Turso
                  · Zod · Lucia auth · LayerChart · TipTap · pdfkit · deployed on
                  Vercel<br /><br />
                  <span class="text-ni-teal">integrates</span> · Affinity CRM · PitchBook
                  · Webflow
                </p>
              </div>

              <!-- impact bar: what it changed -->
              <div class="mt-12 lg:mt-16">
                <p class="kicker reveal text-ni-teal">What it changed</p>
                <div class="mt-5 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
                  {
                    niStats.map((s) => (
                      <div
                        class="reveal border-ni-teal/15 rounded-[3px] border bg-white/[0.03] p-5"
                        style="box-shadow: var(--shadow-paper);"
                      >
                        <p class="t-display text-ni-teal text-[clamp(1.6rem,1.4vw+1rem,2.1rem)] leading-none">
                          {s.big}
                        </p>
                        <p class="text-ni-paper mt-3 font-mono text-[0.7rem] tracking-[0.12em] uppercase">
                          {s.label}
                        </p>
                        <p class="text-ni-paper/65 mt-2 text-[0.9rem] leading-relaxed">
                          {s.note}
                        </p>
                      </div>
                    ))
                  }
                </div>
              </div>
            </div>
          </div>

          <!-- ===== BAND 2 · light product gallery ===== -->
          <div
            class="bg-ni-paper text-ni-ink relative pt-16 pb-[var(--space-section)] lg:pt-24"
          >
            <div class="px-[var(--gutter)]">
              <!-- light-band intro: orients the reader into the product gallery -->
              <div class="max-w-[60ch]">
                <p class="kicker reveal text-ni-teal-deep">
                  Inside the platform
                </p>
                <p
                  class="reveal reveal-1 text-ni-ink mt-3 text-[1.0625rem] leading-relaxed"
                >
                  The screens the investment team lives in — portfolio, exit
                  models, cap tables, spend and board decks — that replaced the
                  CRM and eight spreadsheets.
                </p>
              </div>

              <!-- hero pedestal — now opens below the intro, with real top margin -->
              <div class="relative z-20 mt-8 lg:mt-12">
                <div
                  aria-hidden="true"
                  class="pointer-events-none absolute -inset-x-6 -top-10 -bottom-10 z-0"
                  style="background: radial-gradient(60% 55% at 50% 35%, color-mix(in oklch, var(--color-ni-teal) 22%, transparent), transparent 70%); filter: blur(8px);"
                >
                </div>
                <div class="relative z-10">
                  <Plate
                    src={niDash}
                    tone="niterra"
                    eager
                    alt="Niterra Ventures portfolio dashboard — invested capital, exit-value range and average TVPI above a quarterly revenue trend, recent movers and a projected exit timeline"
                    sizes="(min-width:1024px) 80vw, 92vw"
                    widths={[768, 1280, 1920, 2560]}
                    caption="Portfolio dashboard — invested capital, exit-value range and TVPI up top; a quarterly revenue trend, recent movers and a projected exit timeline below."
                  />
                </div>
              </div>

              <!-- featured showpiece: exit modeling -->
              <div
                class="mt-16 grid gap-8 lg:mt-24 lg:grid-cols-12 lg:items-center"
              >
                <div class="lg:col-span-8">
                  <Plate
                    src={niValuation}
                    tone="niterra"
                    alt="Niterra exit-valuation model showing enterprise value and MOIC across low, mid and high scenarios beside a performance-ratio panel"
                    sizes="(min-width:1024px) 64vw, 92vw"
                    widths={[768, 1280, 1920, 2560]}
                    caption="Exit modeling — enterprise value and MOIC across low / mid / high scenarios, with a live performance-ratio panel."
                  />
                </div>
                <div class="lg:col-span-4">
                  <p class="kicker reveal text-ni-teal-deep">
                    Exit modeling · the showpiece
                  </p>
                  <p
                    class="reveal reveal-1 text-ni-ink mt-3 text-[1.0625rem] leading-relaxed"
                  >
                    A live scenario model from entry to exit, with the waterfall
                    and comps a real diligence deck would carry.
                  </p>
                  <blockquote
                    class="reveal reveal-2 border-ni-teal-deep mt-6 flex gap-3 border-l-2 pl-4"
                  >
                    <DeliveredToken tone="teal" class="mt-1" />
                    <p class="t-emph text-ni-ink text-[1.2rem] leading-snug">
                      The analytical heart of the platform — the scenario math a
                      diligence team builds by hand, made live and reusable
                      across the whole portfolio.
                    </p>
                  </blockquote>
                </div>
              </div>

              <!-- supporting modules -->
              <div class="mt-16 space-y-14 lg:mt-24">
                <div>
                  <p class="kicker reveal text-ni-teal-deep">
                    Portfolio &amp; companies
                  </p>
                  <p
                    class="reveal reveal-1 col-measure text-ni-ink-muted mt-3 text-[0.95rem] leading-relaxed"
                  >
                    Every holding, its rounds and ownership, and per-company
                    financials tracked against plan.
                  </p>
                  <div class="mt-5 grid gap-5 sm:grid-cols-2">
                    <Plate
                      src={niCompanies}
                      tone="niterra"
                      chrome
                      alt="Niterra companies list — every portfolio company with its rounds, investment stages, carry value and ownership"
                      sizes="(min-width:1024px) 39vw, 92vw"
                      widths={[480, 768, 1080, 1280]}
                      caption="Companies — every holding with its rounds, carry value, ownership and major rights."
                    />
                    <Plate
                      src={niCompany}
                      tone="niterra"
                      chrome
                      alt="Niterra per-company financial detail with revenue and net-income charts versus plan and liquidity ratios"
                      sizes="(min-width:1024px) 39vw, 92vw"
                      widths={[480, 768, 1080, 1280]}
                      caption="Per-company detail — revenue, net income and cash generation vs plan, with quarter-over-quarter growth, runway and per-metric variance."
                    />
                  </div>
                </div>

                <div>
                  <p class="kicker reveal text-ni-teal-deep">
                    Cap tables &amp; deal flow
                  </p>
                  <div class="mt-5 grid gap-5 sm:grid-cols-2">
                    <Plate
                      src={niCaptable}
                      tone="niterra"
                      chrome
                      alt="Niterra editable cap table — rounds, per-investor ownership and fully-diluted shares auto-computed from investments"
                      sizes="(min-width:1024px) 39vw, 92vw"
                      widths={[480, 768, 1080, 1280]}
                      caption="Editable cap table — rounds, per-investor ownership and fully-diluted shares, auto-computed from the underlying investments."
                    />
                    <Plate
                      src={niFunnel}
                      tone="niterra"
                      chrome
                      alt="Niterra deal funnel tracking conversion across the investment pipeline stages"
                      sizes="(min-width:1024px) 39vw, 92vw"
                      widths={[480, 768, 1080, 1280]}
                      caption="Deal funnel — conversion from intake to investment across the pipeline, with drop and long-term-follow lanes."
                    />
                  </div>
                </div>

                <div>
                  <p class="kicker reveal text-ni-teal-deep">
                    Spend &amp; forecasting
                  </p>
                  <div class="mt-5 grid gap-5 sm:grid-cols-2">
                    <Plate
                      src={niExpend}
                      tone="niterra"
                      chrome
                      alt="Niterra expenditure dashboard with spend versus budget broken down by domain"
                      sizes="(min-width:1024px) 39vw, 92vw"
                      widths={[480, 768, 1080, 1280]}
                      caption="Expenditure tracking — spend vs budget by domain, with a paid / forecasted split."
                    />
                    <Plate
                      src={niAccuracy}
                      tone="niterra"
                      chrome
                      alt="Niterra forecast-accuracy report comparing forecasted and actual spend per engagement"
                      sizes="(min-width:1024px) 39vw, 92vw"
                      widths={[480, 768, 1080, 1280]}
                      caption="Forecast accuracy — forecasted vs actual spend per engagement, scored by variance."
                    />
                  </div>
                </div>

                <div>
                  <p class="kicker reveal text-ni-teal-deep">
                    Board decks &amp; reporting
                  </p>
                  <div class="mt-5 grid gap-5 sm:grid-cols-2">
                    <Plate
                      src={niPresentation}
                      tone="niterra"
                      chrome
                      alt="Niterra presentation builder showing investment composition, a frozen portfolio snapshot and per-company sections, exported to PowerPoint"
                      sizes="(min-width:1024px) 39vw, 92vw"
                      widths={[480, 768, 1080, 1280]}
                      caption="Presentation builder — composition, frozen snapshots and per-company sections, exported to PPTX. The portfolio deck, in seconds."
                    />
                    <Plate
                      src={niReports}
                      tone="niterra"
                      chrome
                      alt="Niterra financial reports — a profit-and-loss table across quarters with balance-sheet, cash-flow and KPI tabs"
                      sizes="(min-width:1024px) 39vw, 92vw"
                      widths={[480, 768, 1080, 1280]}
                      caption="Financial reports — P&L, balance sheet, cash-flow and KPI tabs, per company."
                    />
                  </div>
                </div>
              </div>

              <!-- footer: attribution + demo disclaimer -->
              <div
                class="reveal border-ni-line mt-16 flex flex-col gap-4 border-t pt-6 sm:flex-row sm:items-center sm:justify-between lg:mt-24"
              >
                <div class="flex items-center gap-3">
                  <Image
                    src={niterraLogo}
                    alt="Venture Lab, Niterra Group"
                    width={40}
                    height={40}
                    class="border-ni-line rounded-[3px] border"
                  />
                  <span class="text-ni-ink font-mono text-[0.75rem]">
                    Venture Lab · Niterra Group
                  </span>
                </div>
                <p
                  class="text-ni-ink-muted font-mono text-[0.72rem] tracking-[0.12em] uppercase"
                >
                  Screens from a public demo seeded with fictional data — no
                  real portfolio data shown.
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ 04 · TWO PRODUCTS, ONE BUILDER ============ -->
    <section
      data-folio="04"
      data-title="Two Commercial Products"
      class="mt-[var(--space-section)]"
    >
      <SectionHeader
        folio="04"
        kicker="Shipped Solo / Two Commercial Products"
        id="proof"
      />
      <h2 class="visually-hidden">Two commercial products, shipped solo</h2>

      <div class="mt-10 lg:mt-14">
        <div
          class="mx-auto w-full max-w-[var(--content-max)] px-[var(--gutter)]"
        >
          <div
            class="border-rule relative overflow-hidden rounded-[var(--panel-radius)] border"
            style="box-shadow: var(--shadow-paper);"
          >
            <div class="grid lg:grid-cols-2 lg:items-stretch">
              <!-- 04A writequit (dark) -->
              <div
                class="bg-wq-ground text-wq-text lg:border-wq-frame relative lg:border-r"
              >
                <div class="px-[var(--gutter)] py-12 lg:py-16">
                  <div
                    class="border-wq-frame text-wq-lime flex items-center gap-2 border-b pb-3 font-mono text-xs"
                  >
                    <span>:wq</span>
                    <span class="text-wq-text/40">— writequit.dev</span>
                    <span
                      class="wq-cursor bg-wq-lime ml-auto inline-block h-3.5 w-2"
                      aria-hidden="true"
                    >
                    </span>
                  </div>

                  <p class="kicker reveal text-wq-lime mt-6">
                    Shipped Solo / Developer Tool
                  </p>
                  <h3
                    class="t-headline reveal reveal-1 text-wq-text mt-3 text-[clamp(1.9rem,2.6vw+1rem,3rem)]"
                  >
                    writequit.dev
                  </h3>
                  <p
                    class="reveal reveal-1 text-wq-text/85 mt-4 max-w-[48ch] text-[1.0625rem] leading-relaxed"
                  >
                    Freelance developers juggle tasks, time, and invoices across
                    three disconnected tools — and lose the thread.
                  </p>

                  <ul
                    class="reveal reveal-2 text-wq-text/90 mt-6 space-y-3 font-mono text-[0.85rem] leading-relaxed"
                  >
                    <li class="flex gap-3">
                      <span class="text-wq-lime" aria-hidden="true">[*]</span>
                      <span>
                        A full commercial SaaS — task manager, time tracker,
                        invoice generator — in one terminal-native tool with vim
                        keybindings and markdown tasks.
                      </span>
                    </li>
                    <li class="flex gap-3">
                      <span class="text-wq-lime" aria-hidden="true">[*]</span>
                      <span>
                        Auth (WorkOS), invoice generation (jsPDF), real-time
                        chat and shared client boards (Convex), password-gated
                        permissioned sharing.
                      </span>
                    </li>
                    <li class="flex gap-3">
                      <span class="text-wq-lime" aria-hidden="true">[*]</span>
                      <span>
                        The product design, the opinionated UX, and the
                        marketing voice — not just the code.
                      </span>
                    </li>
                    <li class="flex gap-3">
                      <span class="text-wq-lime" aria-hidden="true">[*]</span>
                      <span>
                        SvelteKit 5 · Convex · Tailwind 4 · deployed on Vercel.
                      </span>
                    </li>
                  </ul>

                  <div class="mt-9 space-y-5">
                    <Plate
                      src={wqBoard}
                      alt="writequit task board: markdown tasks, a running timer, and status filters in one terminal-style view"
                      tone="dark"
                      chrome
                      sizes="(min-width:1024px) 42vw, 92vw"
                      caption="The board freelancers live in: markdown tasks, running timer, status filters. “manage work, not a workspace.”"
                    />
                    <div class="grid gap-5 sm:grid-cols-2">
                      <Plate
                        src={wqTime}
                        alt="writequit time-tracking sessions with a live running timer"
                        tone="dark"
                        chrome
                        caption="Time tracking with live running timers — part of the same tool, not a second app. “tasks. time. invoices.”"
                      />
                      <Plate
                        src={wqInvoice}
                        alt="writequit invoices generated as PDFs"
                        tone="dark"
                        chrome
                        caption="jsPDF invoice generation — billing built into the same tool, not bolted on."
                      />
                    </div>
                    <Plate
                      src={wqBoardAdmin}
                      alt="writequit shared client board management with a share URL, password, and a live chat panel"
                      tone="dark"
                      chrome
                      caption="Password-protected client boards with live chat (Convex) — permissioned sharing, real-time."
                    />
                    <Plate
                      src={wqClient}
                      alt="the public client view of a writequit shared board, unlocked, with live chat"
                      tone="dark"
                      chrome
                      class="sm:max-w-[82%]"
                      caption="What the client sees: a password-unlocked board with live chat — the sharing surface, from the other side."
                    />
                  </div>

                  <!-- live status bar (Alpine; functional timer) -->
                  <div
                    x-data="wqTimer"
