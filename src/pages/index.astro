---
import Layout from "../layouts/Layout.astro";
import RunningHead from "../components/RunningHead.astro";
import SectionHeader from "../components/SectionHeader.astro";
import Plate from "../components/Plate.astro";
import PhoneFrame from "../components/PhoneFrame.astro";
import DeliveredToken from "../components/DeliveredToken.astro";
import ArchitectureCallout from "../components/ArchitectureCallout.astro";
import { Image } from "astro:assets";

// writequit (dark / terminal)
import wqBoard from "../../content/images/pitch/writequit-board.webp";
import wqTime from "../../content/images/pitch/writequit-time.webp";
import wqInvoice from "../../content/images/pitch/writequit-invoice.webp";
import wqBoardAdmin from "../../content/images/pitch/writequit-board-admin.webp";
import wqClient from "../../content/images/pitch/writequit-client-board.webp";

// pondera (light / friendly)
import poCole from "../../content/images/pitch/pondera-cole.png";
import poPontue from "../../content/images/pitch/pondera-pontue.png";
import poCompare from "../../content/images/pitch/pondera-compare.png";
import poDecida from "../../content/images/pitch/pondera-decida.png";

// Flora (Santos Lab)
import flMapa from "../../content/images/Flora-Mapa.png";
import flDash from "../../content/images/Flora-Dashboard.png";
import flMapaF from "../../content/images/Flora-MapaF.png";
import flApp from "../../content/images/FloraApp-SelectedFarm.png";

// public-facing work
import hoPortal from "../../content/images/HomeOptions.png";
import hoBlog from "../../content/images/HomeOptionsBlog.png";
import liftPortal from "../../content/images/LiftUpPortal.png";

// range / build-for-fun
import gameTitle from "../../content/images/StupidSpiderGameTitle.png";
import gameIG from "../../content/images/StupidSpiderGameIG.png";
import sudoTitle from "../../content/images/SudokouijaTitle.png";
import sudoBoard from "../../content/images/SudokouijaBoard.png";
import goHtmx from "../../content/images/go-htmx.webp";
import gleamHtmx from "../../content/images/HTMX_Gleam.png";

// logo
import niterraLogo from "../../content/images/venturelabngk_logo.jpg";

const niterraMap = [
  "Affinity CRM",
  "     │",
  "     ▼",
  "[ automation layer ]",
  "     │",
  "     ▼",
  "internal portal ──┬──▶ Portfolio Management",
  "                  └──▶ Expense / Contract",
];

const homeOptionsMap = [
  "SvelteKit CRM  ◀──▶  Twilio call center",
  "      │",
  "      ├──▶  AI-assisted call-handoff",
  "      └──▶  Go / HTMX compliance & debt-settlement",
];
---

<Layout title="Felipe Afonso — A product team of one">
  <RunningHead />

  <main id="top">
    <!-- ============ 01 · HERO ============ -->
    <section
      data-folio="01"
      data-title="Cover"
      class="wrap flex min-h-[90vh] flex-col justify-center"
      style="padding-top: calc(var(--running-head-h) + 5vh);"
    >
      <p class="kicker reveal text-accent">
        <span aria-hidden="true">01</span>
        <span class="ml-4 sm:ml-6"
          >Software Engineer · Full-Stack · End-to-End Ownership</span
        >
      </p>
      <h1
        class="t-display reveal reveal-1 mt-6 max-w-[16ch] text-[clamp(2.75rem,6vw+1rem,6.5rem)] text-ink"
      >
        Hand me a problem. I'll hand back a <span class="draw-underline"
          >working product</span
        ><span class="text-accent">.</span>
      </h1>
      <p
        class="reveal reveal-2 col-measure mt-8 text-[clamp(1.0625rem,0.5vw+1rem,1.25rem)] leading-relaxed text-ink"
      >
        I work like an embedded product team of one: I take a problem from rough
        idea to a running product — design, build, deploy — with minimal hand-offs
        in between.
      </p>
      <div
        class="reveal reveal-3 mt-10 flex flex-col gap-3 text-sm sm:flex-row sm:gap-10"
      >
        <a class="ed-link" href="mailto:fmunhozafonso@gmail.com"
          >Start a conversation → fmunhozafonso@gmail.com</a
        >
        <a class="ed-link" href="/resume.pdf">/resume.pdf — the full record</a>
      </div>
    </section>

    <!-- ============ 02 · HOW I WORK ============ -->
    <section
      data-folio="02"
      data-title="Operating Model"
      class="mt-[var(--space-section)]"
    >
      <SectionHeader folio="02" kicker="Operating Model" id="how" />
      <div class="wrap mt-6">
        <p
          class="reveal max-w-[64ch] text-[clamp(1.25rem,1vw+1rem,1.6rem)] leading-snug text-ink"
        >
          I tend to take a problem end-to-end — design, build, deploy, and the
          parts no one volunteers for: auth, billing, the deploy pipeline — so it
          lands as one decision instead of a chain of hand-offs.
        </p>
        <p class="reveal reveal-1 col-measure mt-5 leading-relaxed text-ink">
          I'm comfortable across the stack and across languages, so I can usually
          reach for the tool a problem wants rather than the one I happen to know.
          I lean on AI as a multiplier on delivery speed — it's a big part of why
          the two products below, each with auth, billing, real-time, AI
          extraction, and its own marketing site, shipped from one pair of hands.
          I've also led a small team, so I'm comfortable coordinating when a
          problem is bigger than one person.
        </p>
      </div>
    </section>

    <!-- ============ 03 · TIER 1 CONTRAST PAIR ============ -->
    <section
      data-folio="03"
      data-title="Proof — Two Products, One Builder"
      class="mt-[var(--space-section)]"
    >
      <SectionHeader
        folio="03"
        kicker="Tier One / Two Products, One Builder"
        id="proof"
      />

      <div class="mt-10 lg:mt-14">
        <div class="grid lg:grid-cols-2">
          <!-- 03A writequit (dark) -->
          <div class="relative bg-wq-ground text-wq-text">
            <div
              class="h-[8vh] lg:hidden"
              style="background-image:linear-gradient(to bottom,var(--color-paper),var(--color-wq-ground));"
            >
            </div>
            <div class="px-[var(--gutter)] py-12 lg:py-16">
              <div
                class="flex items-center gap-2 border-b border-wq-frame pb-3 font-mono text-xs text-wq-lime"
              >
                <span>:wq</span>
                <span class="text-wq-text/40">— writequit.dev</span>
                <span
                  class="wq-cursor ml-auto inline-block h-3.5 w-2 bg-wq-lime"
                  aria-hidden="true"></span>
              </div>

              <p class="kicker reveal mt-6 text-wq-lime">
                Tier One / Developer Tool, Shipped Solo
              </p>
              <h3
                class="t-headline reveal reveal-1 mt-3 text-[clamp(1.9rem,2.6vw+1rem,3rem)] text-wq-text"
              >
                writequit.dev
              </h3>
              <p
                class="reveal reveal-1 mt-4 max-w-[48ch] text-[1.0625rem] leading-relaxed text-wq-text/85"
              >
                Freelance developers juggle tasks, time, and invoices across
                three disconnected tools — and lose the thread.
              </p>

              <ul
                class="reveal reveal-2 mt-6 space-y-3 font-mono text-[0.85rem] leading-relaxed text-wq-text/90"
              >
                <li class="flex gap-3">
                  <span class="text-wq-lime" aria-hidden="true">[*]</span>
                  <span
                    >A full commercial SaaS — task manager, time tracker, invoice
                    generator — in one terminal-native tool with vim keybindings
                    and markdown tasks.</span
                  >
                </li>
                <li class="flex gap-3">
                  <span class="text-wq-lime" aria-hidden="true">[*]</span>
                  <span
                    >Auth (WorkOS), invoice generation (jsPDF), real-time chat and
                    shared client boards (Convex), password-gated permissioned
                    sharing.</span
                  >
                </li>
                <li class="flex gap-3">
                  <span class="text-wq-lime" aria-hidden="true">[*]</span>
                  <span
                    >The product design, the opinionated UX, and the marketing
                    voice — not just the code.</span
                  >
                </li>
                <li class="flex gap-3">
                  <span class="text-wq-lime" aria-hidden="true">[*]</span>
                  <span
                    >SvelteKit 5 · Convex · Tailwind 4 · deployed on Vercel.</span
                  >
                </li>
              </ul>

              <div class="mt-9 space-y-5">
                <Plate
                  src={wqBoard}
                  alt="writequit task board: markdown tasks, a running timer, and status filters in one terminal-style view"
                  tone="dark"
                  chrome
                  eager
                  sizes="(min-width:1024px) 42vw, 92vw"
                  caption="The board freelancers live in: markdown tasks, running timer, status filters. “manage work, not a workspace.”"
                />
                <div class="grid gap-5 sm:grid-cols-2">
                  <Plate
                    src={wqTime}
                    alt="writequit time-tracking sessions with a live running timer"
                    tone="dark"
                    chrome
                    caption="Time tracking with live running timers — part of the same tool, not a second app. “tasks. time. invoices.”"
                  />
                  <Plate
                    src={wqInvoice}
                    alt="writequit invoices generated as PDFs"
                    tone="dark"
                    chrome
                    caption="jsPDF invoice generation — billing built into the same tool, not bolted on."
                  />
                </div>
                <Plate
                  src={wqBoardAdmin}
                  alt="writequit shared client board management with a share URL, password, and a live chat panel"
                  tone="dark"
                  chrome
                  caption="Password-protected client boards with live chat (Convex) — permissioned sharing, real-time."
                />
                <Plate
                  src={wqClient}
                  alt="the public client view of a writequit shared board, unlocked, with live chat"
                  tone="dark"
                  chrome
                  class="sm:max-w-[82%]"
                  caption="What the client sees: a password-unlocked board with live chat — the sharing surface, from the other side."
                />
              </div>

              <!-- live status bar (Alpine; functional timer) -->
              <div
                x-data="wqTimer"
                class="mt-9 flex flex-wrap items-center gap-x-4 gap-y-2 border-t border-wq-frame pt-4 font-mono text-[0.8rem] text-wq-text/80"
              >
                <span class="flex items-center gap-2">
                  <span
                    class="h-2 w-2 rounded-full bg-accent"
                    aria-hidden="true"></span>REC
                </span>
                <span class="text-wq-lime" x-text="display">00:48:21</span>
                <span class="text-wq-text/50">:stop</span>
              </div>

              <blockquote
                class="reveal mt-9 flex gap-3 border-l-2 border-wq-lime pl-4"
              >
                <DeliveredToken tone="lime" class="mt-1" />
                <p class="t-emph text-[1.3rem] leading-snug text-wq-text">
                  A complete, billable product — auth to invoice to live client
                  collaboration — shipped end-to-end by one builder.
                  <span
                    class="mt-2 block font-mono text-[0.75rem] not-italic text-wq-text/55"
                    >[Felipe: add metric — e.g., paying customers /
                    time-to-first-invoice]</span
                  >
                </p>
              </blockquote>

              <p
                class="reveal mt-6 font-mono text-[0.72rem] uppercase tracking-[0.12em] text-wq-lime/80"
              >
                a tool, not a lifestyle · write. quit. ship. · for developers
                who'd rather ship than organize
              </p>
            </div>
            <div
              class="h-[8vh] lg:hidden"
              style="background-image:linear-gradient(to bottom,var(--color-wq-ground),var(--color-paper));"
            >
            </div>
          </div>

          <!-- 03B pondera (light) -->
          <div
            class="bg-pondera-paper px-[var(--gutter)] py-12 lg:border-l lg:border-pondera-navy/15 lg:py-16"
          >
            <p class="kicker reveal text-pondera-navy">
              Tier One / Consumer Product, Shipped Solo
            </p>
            <h3
              class="t-headline reveal reveal-1 mt-3 text-[clamp(1.9rem,2.6vw+1rem,3rem)] text-pondera-ink"
            >
              pondera.casa
            </h3>
            <p
              class="t-emph reveal reveal-1 mt-4 text-[clamp(1.4rem,1.4vw+1rem,1.9rem)] leading-snug text-pondera-navy"
            >
              Choose the right house — without getting lost along the way.
            </p>

            <p
              class="reveal reveal-2 mt-6 max-w-[50ch] text-[1.0625rem] leading-relaxed text-pondera-ink"
            >
              Choosing a property means drowning in tabs and gut feeling. pondera
              turns a pasted listing URL into a structured decision — real
              scraping and LLM extraction, not a chat box — then curates,
              compares, and ranks.
            </p>
            <p
              class="reveal reveal-2 mt-3 font-mono text-[0.75rem] tracking-[0.04em] text-pondera-ink"
            >
              Next.js 16 · React 19 · Convex · OpenRouter (gpt-4o-mini)
            </p>

            <ol class="mt-9 space-y-9">
              <li class="reveal grid grid-cols-[auto_1fr] gap-4">
                <span
                  class="font-mono text-2xl leading-none text-pondera-navy"
                  aria-hidden="true">01</span
                >
                <div>
                  <p class="font-mono text-sm">
                    <span class="font-medium text-pondera-navy">Paste</span>
                  </p>
                  <Plate
                    src={poCole}
                    alt="pondera property detail: AI-extracted price, area and neighborhood with a pros, cons and watch-outs card"
                    chrome
                    url="pondera.casa"
                    class="mt-3"
                    captionClass="text-pondera-ink"
                    caption="Paste a link; AI extracts price, area, photos and a pros / cons / watch-outs card. No data entry."
                  />
                </div>
              </li>
              <li class="reveal grid grid-cols-[auto_1fr] gap-4">
                <span
                  class="font-mono text-2xl leading-none text-pondera-navy"
                  aria-hidden="true">02</span
                >
                <div>
                  <p class="font-mono text-sm">
                    <span class="font-medium text-pondera-navy">Score</span>
                  </p>
                  <Plate
                    src={poPontue}
                    alt="pondera gallery with per-property ratings, favorites and portfolio stats"
                    chrome
                    url="pondera.casa"
                    class="mt-3"
                    captionClass="text-pondera-ink"
                    caption="Score each property on a checklist; portfolio stats update as you go."
                  />
                </div>
              </li>
              <li class="reveal grid grid-cols-[auto_1fr] gap-4">
                <span
                  class="font-mono text-2xl leading-none text-pondera-navy"
                  aria-hidden="true">03</span
                >
                <div>
                  <p class="font-mono text-sm">
                    <span class="font-medium text-pondera-navy">Compare</span>
                  </p>
                  <Plate
                    src={poCompare}
                    alt="pondera side-by-side comparison table with the best value per criterion highlighted in gold"
                    chrome
                    url="pondera.casa"
                    class="mt-3"
                    captionClass="text-pondera-ink"
                  >
                    <span slot="caption"
                      >A side-by-side table with <span
                        class="font-semibold text-pondera-gold"
                        >best value per criterion highlighted in gold</span
                      >.</span
                    >
                  </Plate>
                </div>
              </li>
              <li class="reveal grid grid-cols-[auto_1fr] gap-4">
                <span
                  class="font-mono text-2xl leading-none text-pondera-navy"
                  aria-hidden="true">04</span
                >
                <div>
                  <p class="font-mono text-sm">
                    <span class="font-medium text-pondera-navy">Decide</span>
                  </p>
                  <Plate
                    src={poDecida}
                    alt="pondera AI recommendation ranking that explains each position in plain language"
                    chrome
                    url="pondera.casa"
                    class="mt-3"
                    captionClass="text-pondera-ink"
                    caption="AI ranks the options and explains each position in plain language. You decide."
                  />
                </div>
              </li>
            </ol>

            <blockquote
              class="reveal mt-9 flex gap-3 border-l-2 border-pondera-navy pl-4"
            >
              <DeliveredToken tone="accent" class="mt-1" />
              <p class="t-emph text-[1.3rem] leading-snug text-pondera-ink">
                Real AI work — scraping, extraction, curation, ranking — wrapped
                in a polished consumer product and its marketing site, shipped
                end-to-end.
                <span
                  class="mt-2 block font-mono text-[0.75rem] not-italic text-pondera-ink"
                  >[Felipe: add metric — e.g., listings processed / decisions
                  made]</span
                >
              </p>
            </blockquote>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ 04 · NITERRA / VENTURE LAB ============ -->
    <section
      data-folio="04"
      data-title="Venture Lab — Niterra"
      class="mt-[var(--space-section)]"
    >
      <SectionHeader
        folio="04"
        kicker="Tier Two / Internal Product, Shipped Solo"
        title="Venture Lab — Niterra Group"
        id="niterra"
      />
      <div class="wrap mt-8 grid gap-10 lg:grid-cols-12 lg:gap-12">
        <div class="space-y-6 lg:col-span-7">
          <p
            class="reveal max-w-[54ch] text-[1.0625rem] leading-relaxed text-ink"
          >
            A growing venture team ran on a CRM that couldn't carry portfolio
            reporting, expenses, or contracts. I built a custom automation layer
            on Affinity CRM, then scaled it into a full internal portal serving
            multiple business functions — a Portfolio Management module
            (automated quarterly report ingestion, real-time dashboards, custom
            reporting) and an Expense & Contract Management solution.
          </p>
          <ArchitectureCallout
            label="System map"
            lines={niterraMap}
            srText="Affinity CRM feeds an automation layer, which feeds an internal portal containing a Portfolio Management module and an Expense and Contract Management module."
          />
          <div class="grid gap-5 sm:grid-cols-2">
            <div
              class="reveal flex aspect-[16/10] flex-col items-center justify-center gap-2 rounded-[3px] border border-dashed border-rule bg-paper-raised p-4 text-center"
            >
              <span
                class="font-mono text-[0.7rem] uppercase tracking-[0.12em] text-accent"
                >Plate to come</span
              >
              <span class="font-mono text-[0.78rem] leading-relaxed text-ink">
                Portfolio module — dashboards & custom reporting<br /><span
                  class="text-ink-muted">confidential · crop/blur pending</span
                >
              </span>
            </div>
            <div
              class="reveal flex aspect-[16/10] flex-col items-center justify-center gap-2 rounded-[3px] border border-dashed border-rule bg-paper-raised p-4 text-center"
            >
              <span
                class="font-mono text-[0.7rem] uppercase tracking-[0.12em] text-accent"
                >Plate to come</span
              >
              <span class="font-mono text-[0.78rem] leading-relaxed text-ink">
                Expense & Contract module<br /><span class="text-ink-muted"
                  >confidential · crop/blur pending</span
                >
              </span>
            </div>
          </div>
        </div>

        <div class="space-y-6 lg:col-span-5">
          <blockquote class="reveal flex gap-3 border-l-2 border-accent pl-4">
            <DeliveredToken class="mt-1" />
            <p class="t-emph text-[1.4rem] leading-snug text-ink">
              “One internal portal carried reporting, expenses, and contracts
              across multiple business functions — an automation layer built on
              Affinity CRM.”
            </p>
          </blockquote>
          <p class="reveal font-mono text-[0.82rem] leading-relaxed text-ink">
            Replaced manual quarterly report handling with automated ingestion
            and live dashboards.<br /><span class="text-ink-muted"
              >[Felipe: add metric — hours saved per reporting cycle / #
              portfolio companies tracked]</span
            >
          </p>
          <div class="reveal flex items-center gap-3 pt-2">
            <Image
              src={niterraLogo}
              alt="Venture Lab, Niterra Group"
              width={48}
              height={48}
              class="rounded-[3px] border border-rule"
            />
            <span class="font-mono text-[0.75rem] text-ink"
              >Venture Lab · Niterra Group</span
            >
          </div>
        </div>
      </div>
    </section>

    <!-- ============ 05 · FLORA / SANTOS LAB ============ -->
    <section
      data-folio="05"
      data-title="Flora — Santos Lab"
      class="mt-[var(--space-section)]"
    >
      <SectionHeader
        folio="05"
        kicker="Tier Two / Precision-Ag Platform · Web + Mobile"
        title="Flora — Santos Lab"
        id="flora"
      />
      <div class="wrap mt-8">
        <p class="reveal max-w-[62ch] text-[1.0625rem] leading-relaxed text-ink">
          Agronomists needed drone, satellite, and field data fused into
          something they could read on a map — and capture offline in the field.
          I built the React/TypeScript platform (Leaflet + Turf.js) and an
          offline-first React Native field app, and grew from developer into Tech
          Lead of five.
        </p>

        <div class="mt-8 grid gap-6 lg:grid-cols-12 lg:items-start">
          <div class="lg:col-span-8">
            <Plate
              src={flMapa}
              alt="Flora interactive map fusing drone, satellite and field data with geospatial analysis"
              chrome
              url="app.flora"
              sizes="(min-width:1024px) 60vw, 92vw"
              widths={[640, 1024, 1440, 1920]}
              caption="Drone, satellite and field data on one interactive map (Leaflet + Turf.js geospatial analysis)."
            />
          </div>
          <div class="lg:col-span-4 lg:pt-10">
            <PhoneFrame
              src={flApp}
              alt="Flora offline-first React Native field-collection app showing a selected farm"
              caption="Offline-first React Native field app — the same platform, collected where there's no signal."
            />
          </div>
        </div>

        <div class="mt-6 grid gap-6 sm:grid-cols-2">
          <Plate
            src={flDash}
            alt="Flora analytics dashboard with custom charts turning geospatial data into decisions"
            chrome
            url="app.flora"
            widths={[480, 768, 1080, 1440]}
            caption="Analytics dashboards and custom charts turning raw geospatial data into decisions."
          />
          <Plate
            src={flMapaF}
            alt="Flora filtered map with analysis layers"
            chrome
            url="app.flora"
            widths={[480, 768, 1080, 1440]}
            caption="Filtered map + analysis layers — [Felipe: add scale metric, e.g. farms/hectares monitored]."
          />
        </div>

        <blockquote class="reveal mt-8 flex gap-3 border-l-2 border-accent pl-4">
          <DeliveredToken class="mt-1" />
          <p
            class="t-emph max-w-[60ch] text-[1.3rem] leading-snug text-ink"
          >
            A web + mobile platform that put multi-source geospatial data in one
            place — and the case where I went from building to leading the build,
            developer to Tech Lead of 5.
          </p>
        </blockquote>
      </div>
    </section>

    <!-- ============ 06 · PUBLIC-FACING WORK ============ -->
    <section
      data-folio="06"
      data-title="Systems Behind the Screens"
      class="mt-[var(--space-section)]"
    >
      <SectionHeader
        folio="06"
        kicker="Tier Two / Systems Behind the Screens"
        title="The systems users never see"
        id="systems"
      />
      <div class="wrap mt-8 grid gap-10 lg:grid-cols-12 lg:gap-12">
        <div class="space-y-6 lg:col-span-7">
          <p
            class="reveal max-w-[56ch] text-[1.0625rem] leading-relaxed text-ink"
          >
            HomeOptions' real engine was internal. For a call-center sales
            operation I owned a custom SvelteKit CRM wired into Twilio's call
            center, an AI-assisted call-handoff tool, and a Go/HTMX compliance &
            debt-settlement platform — the systems that don't screenshot well but
            run the business.
          </p>
          <ArchitectureCallout
            label="HomeOptions internal"
            lines={homeOptionsMap}
            srText="A custom SvelteKit CRM integrates with the Twilio call center, an AI-assisted call-handoff tool, and a Go and HTMX compliance and debt-settlement platform."
          />
        </div>
        <div class="lg:col-span-5">
          <blockquote class="reveal flex gap-3 border-l-2 border-accent pl-4">
            <DeliveredToken class="mt-1" />
            <p class="t-emph text-[1.4rem] leading-snug text-ink">
              “Three internal systems for a call-center operation — CRM, AI
              call-handoff, and a compliance/debt-settlement platform — owned
              end-to-end.”
            </p>
          </blockquote>
          <p class="reveal mt-4 font-mono text-[0.82rem] leading-relaxed text-ink">
            <span class="text-ink-muted"
              >[Felipe: add metric — calls handled / agent handoff time /
              compliance cases processed]</span
