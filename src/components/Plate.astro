---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  src: ImageMetadata;
  alt: string;
  caption?: string;
  chrome?: boolean;
  url?: string;
  eager?: boolean;
  tone?: "light" | "dark" | "niterra";
  sizes?: string;
  widths?: number[];
  class?: string;
  captionClass?: string;
}

const {
  src,
  alt,
  caption,
  chrome = false,
  url,
  eager = false,
  tone = "light",
  sizes = "(min-width: 1024px) 42vw, 92vw",
  widths = [480, 768, 1080],
  class: cls = "",
  captionClass,
} = Astro.props;

const isDark = tone === "dark";
const isNiterra = tone === "niterra";
const frame = isDark
  ? "border-wq-frame bg-wq-ground"
  : isNiterra
    ? "border-ni-line bg-white"
    : "border-rule bg-paper-raised";
const capColor =
  captionClass ??
  (isDark ? "text-wq-lime" : isNiterra ? "text-ni-ink-muted" : "text-ink");
const hasCaption = Boolean(caption) || Astro.slots.has("caption");
---

<figure class={`group reveal ${cls}`}>
  <div
    class={`overflow-hidden rounded-[3px] border ${frame}`}
    style="box-shadow: var(--shadow-paper);"
  >
    {
      chrome && (
        <div
          class={`flex items-center gap-2 border-b px-3 py-2 ${isDark ? "border-wq-frame" : isNiterra ? "border-ni-line" : "border-rule"}`}
        >
          {isDark ? (
            <span class="font-mono text-xs font-medium text-wq-lime">:wq</span>
          ) : (
            <span class="flex gap-1.5" aria-hidden="true">
              <span
                class={`h-2.5 w-2.5 rounded-full ${isNiterra ? "bg-ni-teal-deep/40" : "bg-rule"}`}
              />
              <span
                class={`h-2.5 w-2.5 rounded-full ${isNiterra ? "bg-ni-teal-deep/40" : "bg-rule"}`}
              />
              <span
                class={`h-2.5 w-2.5 rounded-full ${isNiterra ? "bg-ni-teal-deep/40" : "bg-rule"}`}
              />
            </span>
          )}
          {url && (
            <span
              class={`truncate font-mono text-[0.7rem] ${isNiterra ? "text-ni-ink-muted" : "text-ink"}`}
            >
              {url}
            </span>
          )}
        </div>
      )
    }
    <Image
      src={src}
      alt={alt}
      sizes={sizes}
      widths={widths}
      loading={eager ? "eager" : "lazy"}
      decoding="async"
      class="block h-auto w-full transition-transform duration-500 group-hover:scale-[1.012]"
    />
  </div>
  {
    hasCaption && (
      <figcaption class={`mt-2.5 font-mono text-[0.8125rem] leading-relaxed ${capColor}`}>
        <slot name="caption">{caption}</slot>
      </figcaption>
    )
  }
</figure>
