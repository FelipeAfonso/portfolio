---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  src: ImageMetadata;
  alt: string;
  caption?: string;
  chrome?: boolean;
  url?: string;
  href?: string;
  eager?: boolean;
  tone?: "light" | "dark" | "niterra";
  sizes?: string;
  widths?: number[];
  class?: string;
  captionClass?: string;
  /** entrance variant consumed by motion.ts ("left" | "right" | "scale") */
  reveal?: "left" | "right" | "scale";
  /** scrubbed yPercent shear, desktop only (motion.ts) */
  parallax?: number;
}

const {
  src,
  alt,
  caption,
  chrome = false,
  url,
  href,
  eager = false,
  tone = "light",
  sizes = "(min-width: 1024px) 42vw, 92vw",
  widths = [480, 768, 1080],
  class: cls = "",
  captionClass,
  reveal,
  parallax,
} = Astro.props;

const isDark = tone === "dark";
const isNiterra = tone === "niterra";
const frame = isDark
  ? "border-wq-frame bg-wq-ground"
  : isNiterra
    ? "border-ni-line bg-white"
    : "border-rule bg-paper-raised";
const capColor =
  captionClass ??
  (isDark ? "text-wq-lime" : isNiterra ? "text-ni-ink-muted" : "text-ink");
const dotColor = isNiterra ? "bg-ni-teal-deep/40" : "bg-rule";
const urlColor = isNiterra ? "text-ni-ink-muted" : "text-ink";
const hasCaption = Boolean(caption) || Astro.slots.has("caption");
const halo = isDark
  ? "--color-wq-lime"
  : isNiterra
    ? "--color-ni-teal"
    : "--color-accent";
---

<figure
  class={`group reveal ${cls}`}
  data-reveal={reveal}
  data-parallax={parallax}
>
  <div
    class={`plate-frame overflow-hidden rounded-[3px] border ${frame}`}
    style={`--plate-halo: var(${halo});`}
  >
    {
      chrome && (
        <div
          class={`flex items-center gap-2 border-b px-3 py-2 ${isDark ? "border-wq-frame" : isNiterra ? "border-ni-line" : "border-rule"}`}
        >
          <span class="flex gap-1.5" aria-hidden="true">
            <span class={`h-2.5 w-2.5 rounded-full ${dotColor}`} />
            <span class={`h-2.5 w-2.5 rounded-full ${dotColor}`} />
            <span class={`h-2.5 w-2.5 rounded-full ${dotColor}`} />
          </span>
          {url &&
            (href ? (
              <a
                href={href}
                target="_blank"
                rel="noopener noreferrer"
                class={`truncate font-mono text-[0.7rem] underline-offset-2 hover:underline ${urlColor}`}
              >
                {url}
              </a>
            ) : (
              <span class={`truncate font-mono text-[0.7rem] ${urlColor}`}>
                {url}
              </span>
            ))}
        </div>
      )
    }
    <Image
      src={src}
      alt={alt}
      sizes={sizes}
      widths={widths}
      loading={eager ? "eager" : "lazy"}
      decoding="async"
      class="block h-auto w-full transition-transform duration-500 group-hover:scale-[1.012]"
    />
  </div>
  {
    hasCaption && (
      <figcaption
        class={`mt-2.5 font-mono text-[0.8125rem] leading-relaxed ${capColor}`}
      >
        <slot name="caption">{caption}</slot>
      </figcaption>
    )
  }
</figure>
