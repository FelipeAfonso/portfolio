---
interface Props {
  tone?: "accent" | "lime" | "teal";
  class?: string;
}

const { tone = "accent", class: cls = "" } = Astro.props;
const color =
  tone === "lime"
    ? "var(--color-wq-lime)"
    : tone === "teal"
      ? "var(--color-ni-teal)"
      : "var(--color-accent)";
---

<svg
  aria-hidden="true"
  focusable="false"
  width="22"
  height="22"
  viewBox="0 0 24 24"
  fill="none"
  class={`inline-block shrink-0 ${cls}`}
  style={`color:${color}`}
>
  <path
    d="M12 2.6l2.55 5.3 5.85.78-4.3 4.04 1.08 5.78L12 16.7 6.82 18.5l1.08-5.78-4.3-4.04 5.85-.78L12 2.6z"
    fill="currentColor"
    opacity="0.16"></path>
  <path
    d="M7.2 12.4l3.1 3.1 6.5-7"
    stroke="currentColor"
    stroke-width="2.2"
    stroke-linecap="round"
    stroke-linejoin="round"></path>
</svg>
