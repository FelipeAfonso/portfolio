---
interface Props {
  folio: string;
  kicker: string;
  title?: string;
  id?: string;
  tone?: "ink" | "paper";
}

const { folio, kicker, title, id, tone = "ink" } = Astro.props;
const accent = tone === "paper" ? "text-wq-lime" : "text-accent-bright";
const text = tone === "paper" ? "text-paper" : "text-ink";
---

<header id={id} class="wrap">
  <p class={`section-eyebrow reveal ${accent}`}>
    <span class="num" aria-hidden="true">{folio}</span>{kicker}
  </p>
  {
    title && (
      <h2
        class={`t-headline reveal mt-3 text-[clamp(2rem,3.5vw+1rem,4rem)] ${text}`}
      >
        {title}
      </h2>
    )
  }
  <slot />
</header>
